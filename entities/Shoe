        "Nike",
        "Jordan",
        "Adidas",
        "New Balance",
        "Yeezy",
        "Puma",
        "Reebok",
        "Converse",
        "Vans",
        "Other"
      ]
    },
    "price": {
      "type": "number",
      "title": "Price"
    },
    "size": {
